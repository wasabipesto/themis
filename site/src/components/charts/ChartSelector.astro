---
import type { ChartSelectorOption, ChartContext } from "@lib/charts/types";
import { Icon } from "astro-icon/components";

export interface Props {
  id: string;
  options: ChartSelectorOption<any, any>[];
  context: ChartContext;
}

const { id, options, context } = Astro.props;

// Calculate the count for each option
const optionsWithCounts = options.map((option) => {
  const data = option.dataSelector([], context);
  return {
    ...option,
    count: Array.isArray(data) ? data.length : 0,
  };
});
---

<div class="grid gap-2 grid-cols-1 md:grid-cols-3">
  <div class="flex-col space-y-2">
    {
      optionsWithCounts.map((opt, index) => (
        <div class="bg-base-light text-crust rounded-md drop-shadow-sm px-4 py-2">
          <div class="flex items-center">
            <input
              type="radio"
              id={`chart-option-${id}-${index}`}
              name={`chart-option-${id}`}
              value={index}
              class={`w-5 h-5 mr-4 text-mantle chart-option-${id}`}
            />
            <label for={`chart-option-${id}-${index}`} class="w-full">
              <span>
                {opt.icon && <Icon name={opt.icon} class="inline mb-1 mr-1" />}
                {opt.description}
              </span>
              {opt.count !== undefined && (
                <div class="text-xs text-right">
                  n={opt.count.toLocaleString()}
                </div>
              )}
            </label>
          </div>
        </div>
      ))
    }
  </div>
  <div class="col-span-2">
    <div
      class="bg-base-light [&_h2]:text-2xl [&_figcaption]:text-xs text-crust rounded-md drop-shadow-sm p-4 overflow-x-auto"
    >
      <div
        id={`chart-container-${id}`}
        class="chart-container"
        data-chart-id={id}
        data-options={JSON.stringify(optionsWithCounts)}
        data-context={JSON.stringify(context)}
      >
      </div>
    </div>
  </div>
</div>

<script>
  interface ChartContainerElement extends HTMLElement {
    dataset: {
      chartId: string;
      options: string;
      context: string;
    };
  }

  interface ChartOption {
    id: string;
    description: string;
    config: any;
    count: number;
  }

  // Function to get the selected option based on user input
  function getSelectedOption(
    options: ChartOption[],
    radios: HTMLInputElement[],
  ) {
    for (let i = 0; i < radios.length; i++) {
      if (radios[i].checked) {
        return options[i];
      }
    }
    // Default to first option if none are selected
    return options[0];
  }

  // Get all matching chart container elements
  const chartContainers = document.querySelectorAll(
    ".chart-container",
  ) as NodeListOf<ChartContainerElement>;

  // Set up each chart container
  chartContainers.forEach((container) => {
    try {
      // Extract options and context
      const options = JSON.parse(container.dataset.options) as ChartOption[];
      const context = JSON.parse(container.dataset.context);
      const chartId = container.dataset.chartId;

      // Find options that match the chart ID
      const radios = [
        ...document.querySelectorAll(`.chart-option-${chartId}`),
      ] as HTMLInputElement[];

      // Set the first radio button to checked by default
      if (radios.length > 0) {
        radios[0].checked = true;
      }

      // Initial chart rendering will be handled by specific chart types

      // Set the callbacks for future changes
      radios.forEach((radio) => {
        radio.addEventListener("change", () => {
          const selectedOption = getSelectedOption(options, radios);
          // Dispatch a custom event that specific chart renderers can listen for
          container.dispatchEvent(
            new CustomEvent("optionchange", {
              detail: { option: selectedOption, context },
            }),
          );
        });
      });

      // Trigger the initial render by simulating a change event
      setTimeout(() => {
        const selectedOption = getSelectedOption(options, radios);
        container.dispatchEvent(
          new CustomEvent("optionchange", {
            detail: { option: selectedOption, context },
          }),
        );
      }, 0);
    } catch (error) {
      console.error("Error setting up chart container:", error);
    }
  });
</script>
