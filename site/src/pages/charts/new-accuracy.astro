---
import Base from "@layouts/base.astro";
import Chart from "@components/charts/Chart.astro";
import { getPlatforms, getCategories, getMarketScores } from "@lib/api";
import type { ChartSelectorOption } from "@lib/charts/types";
import { 
  createStandardAccuracyOptions, 
  createScoreTypeOptions,
  createCategoryFilterOptions,
  createResolutionFilterOptions
} from "@lib/charts/presets";

// Download data
const platforms = await getPlatforms();
const categories = await getCategories();
const marketScores = await getMarketScores();

// Context for the charts
const chartContext = { platforms };

// Pre-sort scores for easier percentile calculations
const scores = [...marketScores].sort((a, b) => a.score - b.score);

// Create the options for each chart
const basicFilterOptions = createStandardAccuracyOptions(scores);
const scoreTypeOptions = createScoreTypeOptions(scores);

// Create category filter options
const categoryFilterOptions = createCategoryFilterOptions(
  scores,
  categories,
  (id, description, icon, filter) => ({
    id,
    description,
    icon,
    dataSelector: filter,
    config: {
      type: 'boxplot',
      scoreType: 'brier-midpoint',
      axisConfig: {
        x: { title: 'Platform' },
        y: { title: 'Market score', range: [0, 0.8] }
      }
    }
  })
);

// Create resolution filter options
const resolutionFilterOptions = createResolutionFilterOptions(
  scores,
  (id, description, icon, filter) => ({
    id,
    description,
    icon,
    dataSelector: filter,
    config: {
      type: 'boxplot',
      scoreType: 'brier-midpoint',
      axisConfig: {
        x: { title: 'Platform' },
        y: { title: 'Market score', range: [0, 0.8] }
      }
    }
  })
);

// Create score histogram options
const histogramOptions: ChartSelectorOption<any, any>[] = [
  {
    id: 'brier-midpoint',
    description: 'Market Brier score, calculated with midpoint probability',
    dataSelector: (data: any) => data
      .filter((score: any) => score.score_type === 'brier-midpoint')
      .map((score: any) => ({
        value: score.score,
        platformSlug: score.platform_slug,
      })),
    config: {
      type: 'histogram',
      binCount: 20,
      rangeStart: 0,
      rangeEnd: 1,
      title: 'Histogram of Scores',
      axisConfig: {
        x: { title: 'Midpoint Brier score' },
        y: { title: 'Percent' }
      }
    }
  },
  {
    id: 'brier-average',
    description: 'Market Brier score, averaged over the entire market',
    dataSelector: (data: any) => data
      .filter((score: any) => score.score_type === 'brier-average')
      .map((score: any) => ({
        value: score.score,
        platformSlug: score.platform_slug,
      })),
    config: {
      type: 'histogram',
      binCount: 20,
      rangeStart: 0,
      rangeEnd: 1,
      title: 'Histogram of Scores',
      axisConfig: {
        x: { title: 'Average Brier score' },
        y: { title: 'Percent' }
      }
    }
  },
  {
    id: 'brier-relative',
    description: 'Relative Brier score, calculated for linked markets',
    dataSelector: (data: any) => data
      .filter((score: any) => score.score_type === 'brier-relative')
      .map((score: any) => ({
        value: score.score,
        platformSlug: score.platform_slug,
      })),
    config: {
      type: 'histogram',
      binCount: 20,
      rangeStart: -0.1,
      rangeEnd: 0.1,
      title: 'Histogram of Scores',
      axisConfig: {
        x: { title: 'Relative Brier score' },
        y: { title: 'Percent' }
      }
    }
  },
];
---

<Base title="New Accuracy Charts">
  <div class="p-4 m-2 pb-0 mb-0">
    <h1 class="text-4xl font-bold">New Accuracy Charts</h1>
    <div class="mt-2">
      While calibration is focused on how your predictions match reality,
      accuracy is focused on how often you were correct. The main accuracy score
      we use here is the Brier score, which compares the prediction (usually at
      the market's midpoint) with the resolution at the end of the market. The
      thing to remember is that the Brier score measures how far off you are,
      meaning that a lower score is actually better!
    </div>
  </div>

  <div class="p-4 m-2">
    <Chart
      id="basic-filter"
      type="boxplot"
      title="Basic Filtering"
      description="Select markets to include based on key attributes, such as number of traders, market volume, and duration. Alternatively, pick from a few other selection criteria."
      data={scores}
      options={basicFilterOptions}
      context={chartContext}
    />
  </div>
  <hr class="my-2" />

  <div class="p-4 m-2">
    <Chart
      id="score-type"
      type="boxplot"
      title="Pick a Score"
      description="We use the Brier score by default in most plots, but we calculate many more. Take a look at how the platforms compare when using these alternative scoring methods."
      data={scores}
      options={scoreTypeOptions}
      context={chartContext}
    />
  </div>
  <hr class="my-2" />

  <div class="p-4 m-2">
    <Chart
      id="histogram"
      type="histogram"
      title="Accuracy Histogram"
      description="Are there significant spikes or outliers in the accuracy distribution? For instance, a spike around 0.25 would indicate lots of markets that rested at 50% probability. We'll look at the same scores as above, but showing the distribution in a histogram."
      data={scores}
      options={histogramOptions}
      context={chartContext}
    />
  </div>
  <hr class="my-2" />

  <div class="p-4 m-2">
    <Chart
      id="category"
      type="boxplot"
      title="Category Filtering"
      description="Group markets based on what category they're in. This is determined by how they are categorized on each platform, and not all platforms are supported yet."
      data={scores}
      options={categoryFilterOptions}
      context={chartContext}
    />
  </div>
  <hr class="my-2" />

  <div class="p-4 m-2">
    <Chart
      id="resolution"
      type="boxplot"
      title="Resolution"
      description="At a glance, you might think the resolution of a market shouldn't affect the accuracy much. However, there tend to be distinct types of markets on most platforms (often in the form of 'Will X event happen by Y date?'). If you believe that nothing ever happens, then you might expect that betting NO a lot will make you pretty accurate."
      data={scores}
      options={resolutionFilterOptions}
      context={chartContext}
    />
  </div>
</Base>